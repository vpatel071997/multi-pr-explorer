{
  "name": "multi-pr-explorer",
  "displayName": "Multi-PR Explorer",
  "description": "Workspace-scoped open PRs and assigned issues/work items across GitHub, GitLab, Bitbucket Cloud, and Azure DevOps. Per-repo issue-tracker override (e.g. GitLab code + Azure DevOps tickets).",
  "version": "0.8.0",
  "publisher": "vpatel071997",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:multiPrExplorer.tree"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "multiPrExplorer",
          "title": "Pull Requests",
          "icon": "$(git-pull-request)"
        }
      ]
    },
    "views": {
      "multiPrExplorer": [
        {
          "id": "multiPrExplorer.tree",
          "name": "Open PRs / Issues",
          "icon": "$(git-pull-request)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "multiPrExplorer.tree",
        "contents": "Multi-PR Explorer is workspace-scoped. To get started:\n\n[Add Account](command:multiPrExplorer.addAccount)\n\nThen open a folder whose git remote points at one of your provider hosts (GitHub, GitLab, Bitbucket Cloud, or Azure DevOps).\n\nFor mixed setups (e.g. GitLab code + Azure DevOps tickets), see the [README](https://github.com/vpatel071997/multi-pr-explorer#mixing-providers-gitlab-code--azure-devops-tickets) on how to map an issue tracker per repo."
      }
    ],
    "commands": [
      {
        "command": "multiPrExplorer.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Multi-PR"
      },
      {
        "command": "multiPrExplorer.addAccount",
        "title": "Add Account…",
        "icon": "$(add)",
        "category": "Multi-PR"
      },
      {
        "command": "multiPrExplorer.removeAccount",
        "title": "Remove Account…",
        "category": "Multi-PR"
      },
      {
        "command": "multiPrExplorer.openItem",
        "title": "Open in Browser",
        "category": "Multi-PR"
      },
      {
        "command": "multiPrExplorer.openRepo",
        "title": "Open Repo in Browser",
        "category": "Multi-PR"
      },
      {
        "command": "multiPrExplorer.copyUrl",
        "title": "Copy URL",
        "category": "Multi-PR"
      },
      {
        "command": "multiPrExplorer.mapIssueTracker",
        "title": "Map Issue Tracker…",
        "category": "Multi-PR"
      },
      {
        "command": "multiPrExplorer.manageIssueTrackers",
        "title": "Manage Issue Tracker Overrides…",
        "category": "Multi-PR"
      },
      {
        "command": "multiPrExplorer.testConnections",
        "title": "Test Connections",
        "icon": "$(beaker)",
        "category": "Multi-PR"
      },
      {
        "command": "multiPrExplorer.updateAccountToken",
        "title": "Update Token…",
        "icon": "$(key)",
        "category": "Multi-PR"
      },
      {
        "command": "multiPrExplorer.editAccount",
        "title": "Edit Account…",
        "icon": "$(edit)",
        "category": "Multi-PR"
      },
      {
        "command": "multiPrExplorer.openMyPrs",
        "title": "Open My PRs in Browser",
        "category": "Multi-PR"
      },
      {
        "command": "multiPrExplorer.openAllPrs",
        "title": "Open All PRs in Browser",
        "category": "Multi-PR"
      },
      {
        "command": "multiPrExplorer.createPr",
        "title": "Create PR in Browser",
        "category": "Multi-PR"
      },
      {
        "command": "multiPrExplorer.openMyIssues",
        "title": "Open My Issues in Browser",
        "category": "Multi-PR"
      },
      {
        "command": "multiPrExplorer.openAllIssues",
        "title": "Open All Issues in Browser",
        "category": "Multi-PR"
      },
      {
        "command": "multiPrExplorer.createIssue",
        "title": "Create Issue in Browser",
        "category": "Multi-PR"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "multiPrExplorer.refresh",
          "when": "view == multiPrExplorer.tree",
          "group": "navigation@1"
        },
        {
          "command": "multiPrExplorer.addAccount",
          "when": "view == multiPrExplorer.tree",
          "group": "navigation@2"
        },
        {
          "command": "multiPrExplorer.removeAccount",
          "when": "view == multiPrExplorer.tree",
          "group": "1_modify"
        },
        {
          "command": "multiPrExplorer.manageIssueTrackers",
          "when": "view == multiPrExplorer.tree",
          "group": "1_modify"
        }
      ],
      "view/item/context": [
        {
          "command": "multiPrExplorer.updateAccountToken",
          "when": "view == multiPrExplorer.tree && viewItem == account-status",
          "group": "1_modify@1"
        },
        {
          "command": "multiPrExplorer.editAccount",
          "when": "view == multiPrExplorer.tree && viewItem == account-status",
          "group": "1_modify@2"
        },
        {
          "command": "multiPrExplorer.removeAccount",
          "when": "view == multiPrExplorer.tree && viewItem == account-status",
          "group": "9_destructive"
        },
        {
          "command": "multiPrExplorer.openRepo",
          "when": "view == multiPrExplorer.tree && viewItem == repo",
          "group": "1_open"
        },
        {
          "command": "multiPrExplorer.mapIssueTracker",
          "when": "view == multiPrExplorer.tree && viewItem == repo",
          "group": "2_config"
        },
        {
          "command": "multiPrExplorer.openItem",
          "when": "view == multiPrExplorer.tree && viewItem == item",
          "group": "1_open"
        },
        {
          "command": "multiPrExplorer.copyUrl",
          "when": "view == multiPrExplorer.tree && viewItem == item",
          "group": "1_open"
        },
        {
          "command": "multiPrExplorer.openMyPrs",
          "when": "view == multiPrExplorer.tree && viewItem == section.prs",
          "group": "1_open@1"
        },
        {
          "command": "multiPrExplorer.openAllPrs",
          "when": "view == multiPrExplorer.tree && viewItem == section.prs",
          "group": "1_open@2"
        },
        {
          "command": "multiPrExplorer.createPr",
          "when": "view == multiPrExplorer.tree && viewItem == section.prs",
          "group": "2_create"
        },
        {
          "command": "multiPrExplorer.openMyIssues",
          "when": "view == multiPrExplorer.tree && viewItem == section.issues",
          "group": "1_open@1"
        },
        {
          "command": "multiPrExplorer.openAllIssues",
          "when": "view == multiPrExplorer.tree && viewItem == section.issues",
          "group": "1_open@2"
        },
        {
          "command": "multiPrExplorer.createIssue",
          "when": "view == multiPrExplorer.tree && viewItem == section.issues",
          "group": "2_create"
        }
      ]
    },
    "configuration": {
      "title": "Multi-PR Explorer",
      "properties": {
        "multiPrExplorer.accounts": {
          "type": "array",
          "default": [],
          "markdownDescription": "Configured provider accounts. Use the **Add Account** action in the view title bar to manage. Tokens are stored separately in VS Code SecretStorage and never written to settings.",
          "items": {
            "type": "object",
            "required": [
              "id",
              "label",
              "kind",
              "baseUrl"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique identifier; used as the SecretStorage key for the token."
              },
              "label": {
                "type": "string",
                "description": "Display label shown in the tree."
              },
              "kind": {
                "type": "string",
                "enum": [
                  "github",
                  "gitlab",
                  "bitbucket",
                  "azure"
                ],
                "description": "Provider type."
              },
              "baseUrl": {
                "type": "string",
                "description": "Provider base URL. github.com / gitlab.com for SaaS, full URL for self-hosted."
              },
              "extra": {
                "type": "object",
                "description": "Provider-specific extras (Bitbucket: workspace; Azure: organization)."
              }
            }
          }
        },
        "multiPrExplorer.issueTrackerMap": {
          "type": "array",
          "default": [],
          "markdownDescription": "Optional per-repo override: route the **Issues / Tickets** section of matching repos to a different account (e.g. GitLab code + Azure DevOps tickets). The PR section is unaffected.\n\nExample:\n```jsonc\n[\n  {\n    \"matches\": \"gitlab.acme.com/team/\",\n    \"account\": \"Work ADO\",\n    \"project\": \"Backend\"\n  }\n]\n```",
          "items": {
            "type": "object",
            "required": [
              "matches",
              "account"
            ],
            "properties": {
              "matches": {
                "type": "string",
                "description": "Substring matched (case-insensitive) against the repo's git remote URL."
              },
              "account": {
                "type": "string",
                "description": "Account label or id (the `id` field from multiPrExplorer.accounts) to use for issues on matching repos."
              },
              "project": {
                "type": "string",
                "description": "Azure DevOps Team Project name. Required when the target account is `azure`. Ignored otherwise."
              }
            }
          }
        },
        "multiPrExplorer.refreshIntervalMinutes": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "markdownDescription": "Auto-refresh the tree every N minutes. `0` disables auto-refresh (the default — manual refresh only)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.3.0"
  }
}
